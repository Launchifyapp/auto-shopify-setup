{{ 'launchify-blocks.css' | asset_url | stylesheet_tag }}

<section class="lf-testimonials" style="
  background-color: {{ block.settings.bg_color }};
  padding: {{ block.settings.section_padding }}px 1.5rem;
">
  <div class="lf-testimonials__inner">

    {%- if block.settings.title != blank -%}
      <div class="lf-testimonials__header">
        {%- if block.settings.label != blank -%}
          <span class="lf-testimonials__label">{{ block.settings.label }}</span>
        {%- endif -%}
        <h2 class="lf-testimonials__title" style="color: {{ block.settings.title_color }}">
          {{ block.settings.title }}
        </h2>
        {%- if block.settings.subtitle != blank -%}
          <p class="lf-testimonials__subtitle" style="color: {{ block.settings.text_color }}">
            {{ block.settings.subtitle }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="lf-testimonials__grid lf-testimonials__grid--{{ block.settings.columns }}">

      {%- for i in (1..6) -%}
        {%- assign quote_key    = 'quote_'    | append: i -%}
        {%- assign author_key   = 'author_'   | append: i -%}
        {%- assign role_key     = 'role_'     | append: i -%}
        {%- assign rating_key   = 'rating_'   | append: i -%}
        {%- assign photo_key    = 'photo_'    | append: i -%}

        {%- assign quote  = block.settings[quote_key] -%}
        {%- assign author = block.settings[author_key] -%}

        {%- if quote != blank and author != blank -%}
          {%- assign rating = block.settings[rating_key] | default: 5 -%}
          {%- assign role   = block.settings[role_key] -%}
          {%- assign photo  = block.settings[photo_key] -%}

          <div class="lf-testimonials__card" style="
            background: {{ block.settings.card_bg }};
            border-color: {{ block.settings.card_border_color }};
            border-radius: {{ block.settings.card_radius }}px;
          ">
            <div class="lf-testimonials__stars">
              {%- for star in (1..5) -%}
                <span class="lf-testimonials__star {% if star <= rating %}lf-testimonials__star--filled{% endif %}"
                  style="color: {{ block.settings.star_color }}">★</span>
              {%- endfor -%}
            </div>

            <p class="lf-testimonials__quote" style="color: {{ block.settings.text_color }}">
              "{{ quote }}"
            </p>

            <div class="lf-testimonials__author-row">
              {%- if photo != blank -%}
                <img
                  src="{{ photo | image_url: width: 80 }}"
                  alt="{{ author }}"
                  class="lf-testimonials__photo"
                  width="40"
                  height="40"
                  loading="lazy"
                >
              {%- else -%}
                <div class="lf-testimonials__avatar" style="background: {{ block.settings.accent_color }}">
                  {{ author | slice: 0 | upcase }}
                </div>
              {%- endif -%}

              <div>
                <p class="lf-testimonials__name" style="color: {{ block.settings.title_color }}">
                  {{ author }}
                </p>
                {%- if role != blank -%}
                  <p class="lf-testimonials__role" style="color: {{ block.settings.text_color }}">
                    {{ role }}
                  </p>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</section>

